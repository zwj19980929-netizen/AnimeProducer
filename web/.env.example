# AnimeMatrix Web Frontend Environment Variables
# Copy this file to .env.local and modify as needed

# API Configuration
# The base URL for API requests (used in production builds)
VITE_API_BASE_URL=/api/v1

# API proxy target for development server
VITE_API_TARGET=http://localhost:8000

# Polling Configuration (milliseconds)
VITE_POLLING_INTERVAL=3000
