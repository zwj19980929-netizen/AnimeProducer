# =============================================================================
# AnimeMatrix - 小说转动漫自动化流水线 配置文件
# =============================================================================

# Core Settings
PROJECT_NAME="AnimeMatrix"
DEBUG=True
API_VERSION="v1"
LOG_LEVEL="INFO"

# Database
DATABASE_URL="sqlite:///./animematrix.db"

# =============================================================================
# LLM API Keys
# =============================================================================

# Google Gemini (用于分镜生成和角色提取)
GOOGLE_API_KEY="your_google_api_key_here"

# OpenAI (备选 LLM)
OPENAI_API_KEY="your_openai_api_key_here"

# =============================================================================
# Image Generation
# =============================================================================

# Nano Banana / Flux (主图像生成)
NANO_BANANA_API_KEY="your_nano_banana_api_key_here"
NANO_BANANA_API_URL="https://api.nanobanana.com/v1"

# =============================================================================
# Video Generation
# =============================================================================

# I2V Model (图生视频)
VIDEO_GEN_API_KEY="your_video_gen_api_key_here"
VIDEO_GEN_API_URL="https://api.videogen.com/v1"

# =============================================================================
# TTS Settings (语音合成)
# =============================================================================

TTS_BACKEND="openai"  # openai, edge, google
TTS_API_KEY="your_tts_api_key_here"
TTS_DEFAULT_VOICE="alloy"
TTS_PROVIDER="openai"  # openai, doubao, aliyun, minimax, zhipu

# 豆包 Seed-TTS (火山引擎) - 国内综合表现最强
# 极其拟人，支持呼吸声/吞音，音色克隆仅需几秒样本
DOUBAO_TTS_API_KEY="your_doubao_tts_api_key_here"
DOUBAO_TTS_ENDPOINT="https://openspeech.bytedance.com"
DOUBAO_TTS_APP_ID="your_doubao_app_id_here"

# 阿里云 CosyVoice / Qwen3-TTS
# 零样本语音克隆，流式输出延迟极低
ALIYUN_TTS_API_KEY="your_aliyun_tts_api_key_here"
ALIYUN_TTS_MODEL="cosyvoice-v1"  # cosyvoice-v1, qwen3-tts

# MiniMax Speech-02
# 擅长情感化表达和多角色配音，20+精品预设音色
MINIMAX_API_KEY="your_minimax_api_key_here"
MINIMAX_GROUP_ID="your_minimax_group_id_here"

# 智谱 GLM-4-Voice
# 端到端模型，擅长方言(粤语/重庆话等)和情感互动
ZHIPU_API_KEY="your_zhipu_api_key_here"

# =============================================================================
# VLM Settings (视觉语言模型 - 关键帧评分)
# =============================================================================

VLM_BACKEND="gemini"  # gemini, openai
VLM_MODEL="gemini-1.5-flash"

# =============================================================================
# Redis / Celery (异步任务队列)
# =============================================================================

REDIS_URL="redis://localhost:6379/0"
CELERY_RESULT_EXPIRES=3600

# =============================================================================
# Generation Settings
# =============================================================================

KEYFRAME_CANDIDATES=4
DEFAULT_SHOT_DURATION=3.0
VIDEO_FPS=24
MAX_PARALLEL_SHOTS=4

# =============================================================================
# Retry Settings
# =============================================================================

MAX_RETRIES=3
RETRY_DELAY=1.0

# =============================================================================
# Paths
# =============================================================================

ASSETS_DIR="./assets"
CHARACTERS_DIR="./assets/characters"
RAW_MATERIALS_DIR="./assets/raw_materials"
OUTPUT_DIR="./assets/output"
PROJECTS_DIR="./assets/projects"

# =============================================================================
# Multi-Provider Settings (多厂家模型网关)
# =============================================================================

# Replicate API (用于 PixVerse v4 视频生成)
REPLICATE_API_TOKEN="your_replicate_api_token_here"

# DeepSeek API (LLM)
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_ENDPOINT="https://api.deepseek.com/v1"

# 豆包 / 字节跳动 (Doubao / 火山方舟)
DOUBAO_API_KEY="your_doubao_api_key_here"
DOUBAO_MODEL="doubao-pro-4k"
DOUBAO_ENDPOINT="https://ark.cn-beijing.volces.com/api/v3"

# 阿里云万相 (Wanx / DashScope)
ALIYUN_ACCESS_KEY_ID="your_aliyun_access_key_id_here"
ALIYUN_ACCESS_KEY_SECRET="your_aliyun_access_key_secret_here"
ALIYUN_REGION="cn-shanghai"
ALIYUN_WANX_MODEL="wanx-v1"

# 火山引擎 (Volcengine)
VOLCENGINE_ACCESS_KEY="your_volcengine_access_key_here"
VOLCENGINE_SECRET_KEY="your_volcengine_secret_key_here"
VOLCENGINE_REGION="cn-north-1"

# 默认厂家选择
IMAGE_PROVIDER="google"  # google, aliyun, replicate
VIDEO_PROVIDER="google"  # google, replicate, volcengine, aliyun
LLM_PROVIDER="google"    # google, deepseek, doubao, openai

# 备用厂家顺序（逗号分隔）
BACKUP_IMAGE_PROVIDERS="aliyun,replicate"
BACKUP_VIDEO_PROVIDERS="volcengine,replicate,aliyun"
BACKUP_LLM_PROVIDERS="deepseek,doubao"
